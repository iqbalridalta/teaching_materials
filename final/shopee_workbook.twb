    <column datatype='string' name='[order_id]' role='dimension' type='nominal' />
    <column datatype='integer' caption='Jumlah Item' name='[total_qty]' role='measure' type='quantitative' />
    <column datatype='integer' name='[total_weight_gr]' role='measure' type='quantitative' />
    <column datatype='integer' name='[total_returned_qty]' role='measure' type='quantitative' />
    <column datatype='integer' name='[Total Diskon]' role='measure' type='quantitative' />
    <column datatype='string' name='[product_categories]' role='dimension' type='nominal' />
    <column datatype='integer' name='[num_product_categories]' role='measure' type='quantitative' />
    <column datatype='string' name='[Status Pesanan]' role='dimension' type='nominal' />
    <column datatype='string' name='[Alasan Pembatalan]' role='dimension' type='nominal' />
    <column datatype='string' name='[Opsi Pengiriman]' role='dimension' type='nominal' />
    <column datatype='string' caption='Metode Pembayaran' name='[Metode Pembayaran]' role='dimension' type='nominal' />
    <column datatype='string' name='[Kota/Kabupaten]' role='dimension' type='nominal'>
      <semantic-role value='[city].[name]' />
    </column>
    <column datatype='string' caption='Provinsi' name='[Provinsi]' role='dimension' type='nominal'>
      <semantic-role value='[state/province].[name]' />
    </column>
    <column datatype='integer' name='[Ongkos Kirim Dibayar oleh Pembeli]' role='measure' type='quantitative' />
    <column datatype='integer' name='[Estimasi Potongan Biaya Pengiriman]' role='measure' type='quantitative' />
    <column datatype='integer' caption='Total Pembayaran (GMV)' name='[Total Pembayaran]' role='measure' type='quantitative' />
    <column datatype='integer' name='[Perkiraan Ongkos Kirim]' role='measure' type='quantitative' />
    <column datatype='string' name='[Waktu Pesanan Dibuat]' role='dimension' type='nominal' />
    <column datatype='string' name='[source_file]' role='dimension' type='nominal' />
    <column datatype='integer' caption='Batal (1/0)' name='[is_cancel]' role='measure' type='quantitative' />
    <column datatype='integer' name='[is_completed]' role='measure' type='quantitative' />
    <column datatype='integer' name='[unit_price]' role='measure' type='quantitative' />
    <column datatype='string' caption='Kategori Utama' name='[main_category]' role='dimension' type='nominal' />
    <column datatype='integer' caption='Estimasi Nilai Hilang' name='[lost_gmv_est]' role='measure' type='quantitative' />
    <column datatype='string' caption='Kelompok Wilayah' name='[region_group]' role='dimension' type='nominal' />
    <column datatype='string' caption='Kelompok Alasan Batal' name='[cancel_reason_group]' role='dimension' type='nominal' />
    <column datatype='string' caption='Bulan Pesanan' name='[order_month]' role='dimension' type='ordinal' />
    <column caption='Tingkat Batal' datatype='real' default-format='p0%' name='[Calculation_CancelRate]' role='measure' type='quantitative'>
      <calculation class='tableau' formula='SUM([is_cancel]) / COUNT([order_id])' />
    </column>
    <column caption='Jumlah Pesanan' datatype='integer' name='[Calculation_OrderCount]' role='measure' type='quantitative'>
      <calculation class='tableau' formula='1' />
    </column>
    </datasource>
  </datasources>
  <worksheets>
  <worksheet name='1. Tren GMV'>
    <table>
      <view>
        <datasources><datasource caption='shopee_enriched' name='federated.shopee' /></datasources>
        <datasource-dependencies datasource='federated.shopee'>
        <column-instance column='[Total Pembayaran]' derivation='Sum' name='[sum:Total Pembayaran:qk]' pivot='key' type='quantitative' />
        <column-instance column='[order_month]' derivation='None' name='[none:order_month:nk]' pivot='key' type='nominal' />
        </datasource-dependencies>
        <aggregation value='true' />
      </view>
      <style />
      <panes>
        <pane selection-relaxation-option='selection-relaxation-allow'>
          <view><breakdown value='auto' /></view>
          <mark class='Line' />
        </pane>
      </panes>
      <rows>[federated.shopee].[sum:Total Pembayaran:qk]</rows>
      <cols>[federated.shopee].[none:order_month:nk]</cols>
    </table>
  </worksheet>

  <worksheet name='G2 Line - Tren GMV'>
    <table>
      <view>
        <datasources><datasource caption='shopee_enriched' name='federated.shopee' /></datasources>
        <datasource-dependencies datasource='federated.shopee'>
        <column-instance column='[Total Pembayaran]' derivation='Sum' name='[sum:Total Pembayaran:qk]' pivot='key' type='quantitative' />
        <column-instance column='[order_month]' derivation='None' name='[none:order_month:nk]' pivot='key' type='nominal' />
        </datasource-dependencies>
        <aggregation value='true' />
      </view>
      <style />
      <panes>
        <pane selection-relaxation-option='selection-relaxation-allow'>
          <view><breakdown value='auto' /></view>
          <mark class='Line' />
        </pane>
      </panes>
      <rows>[federated.shopee].[sum:Total Pembayaran:qk]</rows>
      <cols>[federated.shopee].[none:order_month:nk]</cols>
    </table>
  </worksheet>
  <worksheet name='G3 Pie - Komposisi Wilayah'>
    <table>
      <view>
        <datasources><datasource caption='shopee_enriched' name='federated.shopee' /></datasources>
        <datasource-dependencies datasource='federated.shopee'>
        <column-instance column='[region_group]' derivation='None' name='[none:region_group:nk]' pivot='key' type='nominal' />
        <column-instance column='[Calculation_OrderCount]' derivation='Sum' name='[sum:Calculation_OrderCount:qk]' pivot='key' type='quantitative' />
        </datasource-dependencies>
        <aggregation value='true' />
      </view>
      <style />
      <panes>
        <pane selection-relaxation-option='selection-relaxation-allow'>
          <view><breakdown value='auto' /></view>
          <mark class='Pie' />
          <encodings>
            <color column='[federated.shopee].[none:region_group:nk]' />
            <angle column='[federated.shopee].[sum:Calculation_OrderCount:qk]' />
          </encodings>
        </pane>
      </panes>
      <rows></rows>
      <cols></cols>
    </table>
  </worksheet>
  <worksheet name='G4 Treemap - GMV per Kategori'>
    <table>
      <view>
        <datasources><datasource caption='shopee_enriched' name='federated.shopee' /></datasources>
        <datasource-dependencies datasource='federated.shopee'>
        <column-instance column='[main_category]' derivation='None' name='[none:main_category:nk]' pivot='key' type='nominal' />
        <column-instance column='[Total Pembayaran]' derivation='Sum' name='[sum:Total Pembayaran:qk]' pivot='key' type='quantitative' />
        </datasource-dependencies>
        <aggregation value='true' />
      </view>
      <style />
      <panes>
        <pane selection-relaxation-option='selection-relaxation-allow'>
          <view><breakdown value='auto' /></view>
          <mark class='Square' />
          <encodings>
            <color column='[federated.shopee].[none:main_category:nk]' />
            <size column='[federated.shopee].[sum:Total Pembayaran:qk]' />
          </encodings>
        </pane>
      </panes>
      <rows></rows>
      <cols></cols>
    </table>
  </worksheet>
  <worksheet name='G5 Scatter - Qty vs Nilai'>
    <table>
      <view>
        <datasources><datasource caption='shopee_enriched' name='federated.shopee' /></datasources>
        <datasource-dependencies datasource='federated.shopee'>
        <column-instance column='[Total Pembayaran]' derivation='Sum' name='[sum:Total Pembayaran:qk]' pivot='key' type='quantitative' />
        <column-instance column='[total_qty]' derivation='Sum' name='[sum:total_qty:qk]' pivot='key' type='quantitative' />
        <column-instance column='[order_id]' derivation='None' name='[none:order_id:nk]' pivot='key' type='nominal' />
        </datasource-dependencies>
        <aggregation value='true' />
      </view>
      <style />
      <panes>
        <pane selection-relaxation-option='selection-relaxation-allow'>
          <view><breakdown value='auto' /></view>
          <mark class='Circle' />
          <encodings>
            <lod column='[federated.shopee].[none:order_id:nk]' />
          </encodings>
        </pane>
      </panes>
      <rows>[federated.shopee].[sum:Total Pembayaran:qk]</rows>
      <cols>[federated.shopee].[sum:total_qty:qk]</cols>
    </table>
  </worksheet>
  <worksheet name='G7 Heatmap - Pembayaran x Wilayah'>
    <table>
      <view>
        <datasources><datasource caption='shopee_enriched' name='federated.shopee' /></datasources>
        <datasource-dependencies datasource='federated.shopee'>
        <column-instance column='[Metode Pembayaran]' derivation='None' name='[none:Metode Pembayaran:nk]' pivot='key' type='nominal' />
        <column-instance column='[region_group]' derivation='None' name='[none:region_group:nk]' pivot='key' type='nominal' />
        <column-instance column='[Calculation_CancelRate]' derivation='User' name='[usr:Calculation_CancelRate:qk]' pivot='key' type='quantitative' />
        </datasource-dependencies>
        <aggregation value='true' />
      </view>
      <style />
      <panes>
        <pane selection-relaxation-option='selection-relaxation-allow'>
          <view><breakdown value='auto' /></view>
          <mark class='Square' />
          <encodings>
            <color column='[federated.shopee].[usr:Calculation_CancelRate:qk]' />
          </encodings>
        </pane>
      </panes>
      <rows>[federated.shopee].[none:Metode Pembayaran:nk]</rows>
      <cols>[federated.shopee].[none:region_group:nk]</cols>
    </table>
  </worksheet>
  <worksheet name='G11 BAN - Total GMV'>
    <table>
      <view>
        <datasources><datasource caption='shopee_enriched' name='federated.shopee' /></datasources>
        <datasource-dependencies datasource='federated.shopee'>
        <column-instance column='[Total Pembayaran]' derivation='Sum' name='[sum:Total Pembayaran:qk]' pivot='key' type='quantitative' />
        </datasource-dependencies>
        <aggregation value='true' />
      </view>
      <style />
      <panes>
        <pane selection-relaxation-option='selection-relaxation-allow'>
          <view><breakdown value='auto' /></view>
          <mark class='Text' />
          <encodings>
            <text column='[federated.shopee].[sum:Total Pembayaran:qk]' />
          </encodings>
        </pane>
      </panes>
      <rows></rows>
      <cols></cols>
    </table>
  </worksheet>
  </worksheets>
